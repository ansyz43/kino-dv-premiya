---
import Layout from "../layouts/Layout.astro";

// Все фото сезонов — для ленты "Фотохроника сезона" под winners
const PHOTOS_2024 = [
  "3K6A1134","3K6A1301","3K6A1358","3K6A1474","3K6A1931","3K6A2040",
  "3K6A2231","3K6A2517","3K6A2829","3K6A3186","3K6A3214",
].map(n => `/assets/gallery/2024/${n}_resized.jpg`);

const PHOTOS_2025 = [
  "LX3A5728","LX3A5732","LX3A5740","LX3A5746","LX3A5765","LX3A5778",
  "LX3A5786","LX3A5961","LX3A6180","LX3A6184","LX3A6215","LX3A6248",
  "LX3A6615","LX3A6620","LX3A6647","LX3A6690",
].map(n => `/assets/gallery/2025/${n}_resized.jpg`);

type Winner = {
  num: string;        // I, II, III, IV, V, VI
  cat: string;        // короткая категория
  title: string;
  author: string;
  year: string;
  region: string;
  winner?: boolean;   // подсветка Winner
  img?: string;       // фото-карточка
};

type Album = { year: string; label: string; place: string; date: string; cover: string; winners: Winner[] };

const albums: Album[] = [
  {
    year: "2024",
    label: "I сезон",
    place: "Москва",
    date: "Декабрь 2024",
    cover: "/assets/gallery/2024/3K6A1474_resized.jpg",
    winners: [
      { num: "I",   cat: "Полный метр",       title: "Сто лет тому вперёд", author: "Алексей Нужный", year: "2024", region: "Якутия / Приморье", winner: true, img: "/assets/gallery/2024/3K6A2040_resized.jpg" },
      { num: "II",  cat: "Режиссура",         title: "Айта",                author: "Степан Бурнашёв", year: "2022", region: "Якутия", winner: true, img: "/assets/gallery/2024/3K6A2829_resized.jpg" },
      { num: "III", cat: "Сценарий",          title: "Не одна дома",        author: "Радда Новикова", year: "2023", region: "Сахалин", img: "/assets/gallery/2024/3K6A1134_resized.jpg" },
      { num: "IV",  cat: "Дебют",             title: "Куба, Куба",          author: "Кирилл Кравченко", year: "2024", region: "Приморье", img: "/assets/gallery/2024/3K6A3214_resized.jpg" },
      { num: "V",   cat: "Короткий метр",     title: "Тойук",               author: "Виктор Аммосов", year: "2023", region: "Якутия", img: "/assets/gallery/2024/3K6A3186_resized.jpg" },
      { num: "VI",  cat: "За вклад в развитие", title: "Дмитрий Давыденко", author: "Продюсер", year: "Якутск", region: "Якутия", winner: true, img: "/assets/gallery/2024/3K6A1474_resized.jpg" },
    ],
  },
  {
    year: "2025",
    label: "II сезон",
    place: "Улан-Удэ",
    date: "Сентябрь 2025",
    cover: "/assets/gallery/2025/LX3A5728_resized.jpg",
    winners: [
      { num: "I",   cat: "Полный метр",       title: "Огонь",                      author: "Алексей Нужный", year: "2024", region: "Камчатка", winner: true, img: "/assets/gallery/2025/LX3A5746_resized.jpg" },
      { num: "II",  cat: "Режиссура",         title: "Чёрная молния возвращается", author: "Дмитрий Давыдов", year: "2024", region: "Якутия", winner: true, img: "/assets/gallery/2025/LX3A6180_resized.jpg" },
      { num: "III", cat: "Сценарий",          title: "Бэлэх",                       author: "Степан Бурнашёв", year: "2024", region: "Якутия", img: "/assets/gallery/2025/LX3A6615_resized.jpg" },
      { num: "IV",  cat: "Дебют",             title: "Триозёрск",                   author: "Сергей Кузнецов", year: "2024", region: "Хабаровск", img: "/assets/gallery/2025/LX3A5732_resized.jpg" },
      { num: "V",   cat: "Короткий метр",     title: "Куда мы едем",                author: "Татьяна Эверстова", year: "2024", region: "Якутия", img: "/assets/gallery/2025/LX3A5740_resized.jpg" },
      { num: "VI",  cat: "За вклад",          title: "Алёна Шумакова",              author: "Программный директор", year: "Бурятия", region: "Бурятия", winner: true, img: "/assets/gallery/2025/LX3A5765_resized.jpg" },
    ],
  },
];
---
<Layout title={`Архив · Дальневосточная Кинопремия 2026`} active={"archive"}>

<section class="page-hero v2">
  <div class="page-hero-eyebrow"><span class="dot"></span><span>Архив победителей</span></div>
  <h1 class="page-hero-title" data-text-reveal>Два <em>сезона</em></h1>
  <p class="page-hero-lead">Шорт-листы и&nbsp;победители прошедших церемоний — I&nbsp;сезон в&nbsp;Москве (2024) и&nbsp;II&nbsp;сезон в&nbsp;Улан-Удэ (2025). Сезон III&nbsp;откроется после приёма заявок 2026.</p>
</section>

<!-- Year scrubber slider -->
<nav class="archive-nav-pills">
  {albums.map((a) => (
    <a href={"#year-" + a.year} class="archive-nav-pill">
      <span class="archive-nav-pill-year">{a.year}</span>
      <span class="archive-nav-pill-place">{a.place}</span>
    </a>
  ))}
</nav>

{albums.map((album, ai) => (
  <article class={"album reveal" + (ai % 2 ? " album-flip" : "")} id={"year-" + album.year}>

    <!-- Cover hero -->
    <header class="album-cover">
      <img src={album.cover} alt={album.label} class="album-cover-img" />
      <div class="album-cover-overlay">
        <div class="album-cover-eyebrow">
          <span class="dot"></span>
          <span>{album.label} · {album.place}</span>
        </div>
        <h2 class="album-cover-year">{album.year}</h2>
        <div class="album-cover-date">{album.date}</div>
      </div>
    </header>

    <!-- Winners — magazine alternating layout -->
    <div class="album-winners">
      {album.winners.map((w, i) => (
        <article class={"album-winner" + (i % 2 ? " flip" : "") + (w.winner ? " is-winner" : "")}>
          <div class="album-winner-photo">
            {w.img && <img src={w.img} alt={w.title} loading="lazy" />}
            <div class="album-winner-num">{w.num}</div>
            {w.winner && <div class="album-winner-badge">Winner</div>}
          </div>
          <div class="album-winner-body">
            <div class="album-winner-cat">{w.cat}</div>
            <h3 class="album-winner-title">{w.title}</h3>
            <div class="album-winner-author">{w.author} · {w.year}</div>
            <div class="album-winner-region">Регион — {w.region}</div>
          </div>
        </article>
      ))}
    </div>

    <!-- Фотохроника сезона — горизонтальная лента всех фото года -->
    <section class="album-photos">
      <header class="album-photos-head">
        <div class="page-hero-eyebrow"><span class="dot"></span><span>Фотохроника · {album.year}</span></div>
        <h3>Кадры <em>{album.label}</em></h3>
        <p>{album.year === "2024" ? PHOTOS_2024.length : PHOTOS_2025.length} фотографий · {album.place} · {album.date}</p>
      </header>
      <div class="album-photos-rail">
        {(album.year === "2024" ? PHOTOS_2024 : PHOTOS_2025).map((src, i) => (
          <a class="album-photos-card" href={src} target="_blank" rel="noopener" aria-label={`Фото ${i + 1}`}>
            <img src={src} alt="" loading="lazy" />
          </a>
        ))}
      </div>
    </section>

  </article>
))}

</Layout>
